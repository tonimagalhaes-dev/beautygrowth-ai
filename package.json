{
  "name": "beauty-growth-ai",
  "version": "0.1.0",
  "description": "BeautyGrowth AI - Multi-agent AI platform for aesthetic clinics",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js -d src/database/data-source.ts",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:generate": "npm run typeorm -- migration:generate",
    "proto:gen": "bash scripts/proto-gen.sh"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.7.15",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "@qdrant/js-client-rest": "^1.18.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.79.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "typeorm": "^0.3.20",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "fast-check": "^3.19.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.4",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.2.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@shared/(.*)$": "<rootDir>/shared/$1",
      "^@auth/(.*)$": "<rootDir>/modules/auth/$1",
      "^@clinic/(.*)$": "<rootDir>/modules/clinic/$1",
      "^@brand/(.*)$": "<rootDir>/modules/brand/$1",
      "^@agent-config/(.*)$": "<rootDir>/modules/agent-config/$1",
      "^@business-memory/(.*)$": "<rootDir>/modules/business-memory/$1",
      "^@agent-memory/(.*)$": "<rootDir>/modules/agent-memory/$1",
      "^@knowledge-hub/(.*)$": "<rootDir>/modules/knowledge-hub/$1",
      "^@model-registry/(.*)$": "<rootDir>/modules/model-registry/$1",
      "^@prompt-registry/(.*)$": "<rootDir>/modules/prompt-registry/$1",
      "^@guardrails/(.*)$": "<rootDir>/modules/guardrails/$1",
      "^@privacy/(.*)$": "<rootDir>/modules/privacy/$1",
      "^@observability/(.*)$": "<rootDir>/modules/observability/$1",
      "^@event-bus/(.*)$": "<rootDir>/modules/event-bus/$1"
    }
  }
}
