# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=beautygrowth
DATABASE_PASSWORD=beautygrowth_dev
DATABASE_NAME=beautygrowth_dev

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=beautygrowth
S3_SECRET_KEY=beautygrowth_dev
S3_BUCKET=beauty-growth-ai
S3_REGION=us-east-1

# Application
APP_PORT=3000
NODE_ENV=development
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# LangGraph gRPC Service
LANGGRAPH_HOST=localhost
LANGGRAPH_PORT=50051
LANGGRAPH_CALL_TIMEOUT_MS=30000
LANGGRAPH_POOL_MIN=1
LANGGRAPH_POOL_MAX=10
LANGGRAPH_PROTO_PATH=proto/agent_orchestration.proto

# Circuit Breaker
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_SUCCESS_THRESHOLD=3
CIRCUIT_BREAKER_TIMEOUT=30000
CIRCUIT_BREAKER_RESET_TIMEOUT=60000

# Cache
CACHE_TTL_GUARDRAILS_TENANT=300
CACHE_TTL_GUARDRAILS_SYSTEM=600
CACHE_TTL_PROMPTS=600
CACHE_TTL_DEFAULT=300

# Google Gemini (LLM Provider)
GOOGLE_API_KEY=your-google-api-key-here
